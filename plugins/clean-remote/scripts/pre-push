#!/bin/sh
# clean-remote pre-push guard (installed into .git/hooks/pre-push by `setup`).
#
# Refuses to push to the configured public remote any ref whose tree still contains
# a REMOTE_EXCLUDE path. This turns "remember to publish via the skill" into a hard
# stop: the private paths CANNOT reach the public remote by accident.
#
# Per-branch model: each pushed ref is checked against the private-path list of the dev
# branch that owns its TARGET public branch — not a single global source. For a push
# `clean-remote/publish-x:feat/a` we reverse-map the target `feat/a` to the local dev
# branch that publishes there and read THAT branch's committed REMOTE_EXCLUDE.md (its full
# list — so a leak is caught even if the pushed tree itself dropped the file). When no dev
# branch maps to the target, we fall back to the pushed tree's OWN REMOTE_EXCLUDE.md, which
# (because it lists itself) makes any raw private tree self-incriminate.
#
# Args: $1 = remote name, $2 = remote URL. Refs arrive on stdin as:
#   <local ref> <local sha> <remote ref> <remote sha>
#
# This is a guard against accidents, not a security boundary — it is bypassable
# with `git push --no-verify`.

remote_name="$1"
cr_remote="$(git config clean-remote.remote 2>/dev/null || echo origin)"

# Only guard the configured public remote; let any other remote through.
[ "$remote_name" = "$cr_remote" ] || exit 0

template="$(git config clean-remote.publishBranchTemplate 2>/dev/null)"
[ -n "$template" ] || template='%s'

# Read the exclude patterns committed in <ref>'s REMOTE_EXCLUDE.md.
excl_from() {  # $1 = ref or sha
  git show "$1:REMOTE_EXCLUDE.md" 2>/dev/null \
    | sed 's/#.*//' | sed 's/[[:space:]]*$//' | grep -v '^[[:space:]]*$'
}

# Public branch for a local dev branch: per-branch override, else the template applied.
publish_branch_for() {  # $1 = local branch
  o="$(git config "branch.$1.cleanRemotePublish" 2>/dev/null)"
  [ -n "$o" ] && { printf '%s\n' "$o"; return; }
  # shellcheck disable=SC2059
  printf "$template\n" "$1"
}

# Local dev branch that publishes to a given public branch name (first match), or empty.
devbranch_for_public() {  # $1 = public branch name
  for b in $(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null); do
    [ "$(publish_branch_for "$b")" = "$1" ] && { printf '%s\n' "$b"; return; }
  done
}

status=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # skip branch deletions (local sha is all zeros)
  case "$local_sha" in *[!0]*) ;; *) continue ;; esac

  target="${remote_ref#refs/heads/}"
  dev="$(devbranch_for_public "$target")"
  if [ -n "$dev" ]; then
    excl="$(excl_from "refs/heads/$dev")"      # the owning dev branch's full private list
  else
    excl="$(excl_from "$local_sha")"           # fallback: the pushed tree's own self-listing
  fi
  [ -n "$excl" ] || continue                   # nothing declared private → nothing to guard

  hits="$(git ls-tree -r --name-only "$local_sha" -- $excl 2>/dev/null)"
  if [ -n "$hits" ]; then
    echo "clean-remote: BLOCKED push to '$remote_name' — '$local_ref' -> '$target' still contains private paths:" >&2
    echo "$hits" | sed 's/^/      /' >&2
    echo "  Publish via the clean-remote 'publish' skill (it strips these), instead of pushing this branch." >&2
    status=1
  fi
done
exit $status
